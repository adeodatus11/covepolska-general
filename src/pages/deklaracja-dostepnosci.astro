          footer_accessibility: "Deklaracja dostępności"
        },
        en: {
          nav_about: "About project",
          nav_partners: "Partners",
          nav_news: "News",
          nav_offer: "Our offer",
          nav_contact: "Contact",
          declaration_kicker: "Digital accessibility",
          declaration_h1: "Accessibility statement",
          declaration_lead: "This statement describes the digital accessibility of the COVE Polska website and selected project subdomains.",
          summary_h2: "Key information",
          summary_site_label: "Website",
          summary_status_label: "Status",
          summary_status_value: "partially compliant",
          summary_date_label: "Statement date",
          summary_contact_label: "Contact",
          scope_h2: "Scope of the statement",
          scope_p1: "COVE Polska makes efforts to ensure that the website and project services are accessible to the widest possible group of users, including people with disabilities.",
