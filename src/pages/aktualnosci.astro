---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aktualności – COVE Polska</title>
    <meta
      name="description"
      content="Aktualności COVE Polska z kanałów LinkedIn, Facebook i YouTube. Sprawdź bieżące informacje o działaniach projektu."
    />
    <meta property="og:title" content="Aktualności – COVE Polska" />
    <meta property="og:description" content="Aktualności COVE Polska z kanałów LinkedIn, Facebook i YouTube." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="http://new.covepolska.pl/aktualnosci/" />
    <meta property="og:image" content="http://new.covepolska.pl/assets/cove-polska-logo.png" />
    <meta name="theme-color" content="#0d2b66" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}hub.css`} />
  </head>
  <body>
    <header class="site-header" role="banner">
      <div class="header-inner">
        <div class="logo-strip">
          <a href="https://win4smes.eu" target="_blank" rel="noopener noreferrer" aria-label="WIN4SMEs website">
            <img src={`${base}assets/Logo-2025.png`} alt="WIN4SMEs" />
          </a>
          <div class="logo-divider"></div>
          <a href={base} aria-label="COVE Polska – strona główna">
            <img src={`${base}assets/cove-polska-logo.png`} alt="COVE Polska" />
          </a>
          <div class="logo-divider"></div>
          <a href="https://ec.europa.eu/info/funding-tenders/opportunities/portal/screen/home" target="_blank" rel="noopener noreferrer" aria-label="EU Funding portal">
            <img src={`${base}assets/PL_Co-fundedbytheEU_RGB_POS.png`} alt="Dofinansowane przez Unię Europejską" id="eu-logo-header" />
          </a>
        </div>

        <nav class="header-nav" aria-label="Main navigation">
          <a href={`${base}#about`} data-i18n="nav_about">O projekcie</a>
          <a href={`${base}#partners`} data-i18n="nav_partners">Partnerzy</a>
          <a href={`${base}aktualnosci/`} class="active" data-i18n="nav_news">Aktualności</a>
          <a href={`${base}nasze-dzialania/`} data-i18n="nav_offer">Nasza oferta</a>
          <a href={`${base}kontakt/`} data-i18n="nav_contact">Kontakt</a>
        </nav>

        <button class="hamburger" id="hamburger-btn" aria-label="Menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>

        <div class="lang-switch" role="group" aria-label="Language selection">
          <button class="lang-btn" id="btn-en" type="button" aria-pressed="false">EN</button>
          <button class="lang-btn active" id="btn-pl" type="button" aria-pressed="true">PL</button>
        </div>
      </div>
    </header>

    <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
      <a href={`${base}#about`} data-i18n="nav_about">O projekcie</a>
      <a href={`${base}#partners`} data-i18n="nav_partners">Partnerzy</a>
      <a href={`${base}aktualnosci/`} class="active" data-i18n="nav_news">Aktualności</a>
      <a href={`${base}nasze-dzialania/`} data-i18n="nav_offer">Nasza oferta</a>
      <a href={`${base}kontakt/`} data-i18n="nav_contact">Kontakt</a>
    </nav>

    <main>
      <section class="hero news-hero" aria-labelledby="news-heading">
        <div class="container hero-inner">
          <p class="section-kicker" data-i18n="news_kicker">Aktualności</p>
          <h1 id="news-heading" data-i18n="news_h1">Aktualności z kanałów COVE Polska</h1>
          <p class="hero-lead" data-i18n="news_lead">
            Bieżące informacje publikujemy w mediach społecznościowych. Tutaj zbieramy kanały projektu w jednym miejscu.
          </p>
        </div>
      </section>

      <section class="news-section" aria-label="Aktualności z mediów społecznościowych COVE Polska">
        <div class="container social-feed-stack">
          <div class="feed-intro">
            <h2 data-i18n="feed_h2">Feed aktualności</h2>
            <p data-i18n="feed_p">
              LinkedIn, Facebook i YouTube są bieżącymi kanałami komunikacji projektu. Każdy blok prowadzi bezpośrednio do aktualnego źródła.
            </p>
          </div>

          <div class="feed-grid">
            <article class="feed-card feed-card-wide">
              <div class="feed-frame">
                <div class="feed-frame-header">
                  <span class="feed-service">LinkedIn</span>
                  <span class="feed-live" data-i18n="feed_source">źródło aktualności</span>
                </div>
                <div class="feed-placeholder">
                  <span class="feed-mark linkedin" aria-hidden="true">in</span>
                  <div>
                    <h3 data-i18n="linkedin_cove_title">COVE Polska na LinkedIn</h3>
                    <p data-i18n="linkedin_cove_desc">Komunikaty, relacje z działań i informacje o zasobach polskiego partnerstwa.</p>
                  </div>
                  <a class="feed-button" href="https://www.linkedin.com/company/cove-polska/" target="_blank" rel="noopener noreferrer" data-i18n="open_feed">Przejdź do feedu</a>
                </div>
              </div>
            </article>

            <article class="feed-card">
              <div class="feed-frame">
                <div class="feed-frame-header">
                  <span class="feed-service">LinkedIn</span>
                  <span class="feed-live" data-i18n="feed_source">źródło aktualności</span>
                </div>
                <div class="feed-placeholder">
                  <span class="feed-mark linkedin" aria-hidden="true">in</span>
                  <div>
                    <h3 data-i18n="linkedin_win_title">WIN4SMEs na LinkedIn</h3>
                    <p data-i18n="linkedin_win_desc">Aktualności z międzynarodowego poziomu projektu i sieci partnerów.</p>
                  </div>
                  <a class="feed-button" href="https://www.linkedin.com/company/win4smes/posts/?feedView=all" target="_blank" rel="noopener noreferrer" data-i18n="open_feed">Przejdź do feedu</a>
                </div>
              </div>
            </article>

            <article class="feed-card">
              <div class="feed-frame">
                <div class="feed-frame-header">
                  <span class="feed-service">Facebook</span>
                  <span class="feed-live" data-i18n="feed_source">źródło aktualności</span>
                </div>
                <div class="feed-placeholder">
                  <span class="feed-mark facebook" aria-hidden="true">f</span>
                  <div>
                    <h3 data-i18n="facebook_title">COVE Polska na Facebooku</h3>
                    <p data-i18n="facebook_desc">Krótsze informacje, zapowiedzi i relacje publikowane dla lokalnej społeczności.</p>
                  </div>
                  <a class="feed-button" href="https://www.facebook.com/profile.php?id=61573736918326" target="_blank" rel="noopener noreferrer" data-i18n="open_feed">Przejdź do feedu</a>
                </div>
              </div>
            </article>

            <article class="feed-card feed-card-wide">
              <div class="feed-frame">
                <div class="feed-frame-header">
                  <span class="feed-service">YouTube</span>
                  <span class="feed-live" data-i18n="feed_source">źródło aktualności</span>
                </div>
                <div class="feed-placeholder">
                  <span class="feed-mark youtube" aria-hidden="true">yt</span>
                  <div>
                    <h3 data-i18n="youtube_title">COVE Polska na YouTube</h3>
                    <p data-i18n="youtube_desc">Materiały wideo, nagrania i publikacje multimedialne projektu.</p>
                  </div>
                  <a class="feed-button" href="https://www.youtube.com/@COVEPolska" target="_blank" rel="noopener noreferrer" data-i18n="open_feed">Przejdź do feedu</a>
                </div>
              </div>
            </article>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-logos" aria-label="Logotypy projektu i finansowania">
          <img src={`${base}assets/Logo-2025.png`} alt="WIN4SMEs" />
          <img id="eu-logo-footer" src={`${base}assets/PL_Co-fundedbytheEU_RGB_POS.png`} alt="Współfinansowane przez Unię Europejską" />
          <a href="https://www.wroclaw.pl/" target="_blank" rel="noopener noreferrer" aria-label="Wrocław website">
            <img class="wroclaw-logo" id="wroclaw-logo-footer" src={`${base}assets/wroclaw-miasto-spotkan.png`} alt="Wrocław Miasto Spotkań" />
          </a>
        </div>
        <p data-i18n="footer_note">
          Współfinansowane przez Unię Europejską. Wyrażone poglądy i opinie są wyłącznie poglądami autorów i niekoniecznie odzwierciedlają stanowisko Unii Europejskiej lub Europejskiej Agencji Wykonawczej ds. Edukacji i Kultury (EACEA).
        </p>
      </div>
    </footer>

    <script define:vars={{ base }}>
      const I18N = {
        pl: {
          nav_about: "O projekcie",
          nav_partners: "Partnerzy",
          nav_news: "Aktualności",
          nav_offer: "Nasza oferta",
          nav_contact: "Kontakt",
          news_kicker: "Aktualności",
          news_h1: "Aktualności z kanałów COVE Polska",
          news_lead: "Bieżące informacje publikujemy w mediach społecznościowych. Tutaj zbieramy kanały projektu w jednym miejscu.",
          feed_h2: "Feed aktualności",
          feed_p: "LinkedIn, Facebook i YouTube są bieżącymi kanałami komunikacji projektu. Każdy blok prowadzi bezpośrednio do aktualnego źródła.",
          feed_source: "źródło aktualności",
          open_feed: "Przejdź do feedu",
          linkedin_cove_title: "COVE Polska na LinkedIn",
          linkedin_cove_desc: "Komunikaty, relacje z działań i informacje o zasobach polskiego partnerstwa.",
          linkedin_win_title: "WIN4SMEs na LinkedIn",
          linkedin_win_desc: "Aktualności z międzynarodowego poziomu projektu i sieci partnerów.",
          facebook_title: "COVE Polska na Facebooku",
          facebook_desc: "Krótsze informacje, zapowiedzi i relacje publikowane dla lokalnej społeczności.",
          youtube_title: "COVE Polska na YouTube",
          youtube_desc: "Materiały wideo, nagrania i publikacje multimedialne projektu.",
          footer_note: "Współfinansowane przez Unię Europejską. Wyrażone poglądy i opinie są wyłącznie poglądami autorów i niekoniecznie odzwierciedlają stanowisko Unii Europejskiej lub Europejskiej Agencji Wykonawczej ds. Edukacji i Kultury (EACEA)."
        },
        en: {
          nav_about: "About project",
          nav_partners: "Partners",
          nav_news: "News",
          nav_offer: "Our offer",
          nav_contact: "Contact",
          news_kicker: "News",
          news_h1: "News from COVE Polska channels",
          news_lead: "We publish current updates on social media. This page gathers the project channels in one place.",
          feed_h2: "News feed",
          feed_p: "LinkedIn, Facebook and YouTube are the current communication channels for the project. Each block leads directly to the latest source.",
          feed_source: "news source",
          open_feed: "Open feed",
          linkedin_cove_title: "COVE Polska on LinkedIn",
          linkedin_cove_desc: "Announcements, activity reports and updates about resources from the Polish partnership.",
          linkedin_win_title: "WIN4SMEs on LinkedIn",
          linkedin_win_desc: "Updates from the international project level and partner network.",
          facebook_title: "COVE Polska on Facebook",
          facebook_desc: "Short updates, announcements and reports for the local community.",
          youtube_title: "COVE Polska on YouTube",
          youtube_desc: "Video materials, recordings and multimedia project publications.",
          footer_note: "Co-funded by the European Union. Views and opinions expressed are those of the authors only and do not necessarily reflect those of the European Union or EACEA."
        }
      };

      const LANG_STORAGE_KEY = "covePolskaLang";

      function getSavedLang() {
        try {
          const stored = localStorage.getItem(LANG_STORAGE_KEY);
          return stored === "en" || stored === "pl" ? stored : "pl";
        } catch (error) {
          return "pl";
        }
      }

      function setLang(lang, persist = true) {
        document.documentElement.setAttribute("lang", lang);
        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.dataset.i18n;
          if (I18N[lang][key]) el.textContent = I18N[lang][key];
        });
        document.getElementById("btn-pl").classList.toggle("active", lang === "pl");
        document.getElementById("btn-en").classList.toggle("active", lang === "en");
        document.getElementById("btn-pl").setAttribute("aria-pressed", lang === "pl");
        document.getElementById("btn-en").setAttribute("aria-pressed", lang === "en");
        const src = lang === "pl" ? `${base}assets/wroclaw-miasto-spotkan.png` : `${base}assets/wroclaw-meeting-place-better.png`;
        const alt = lang === "pl" ? "Wrocław Miasto Spotkań" : "Wrocław the Meeting Place";
        document.querySelectorAll("#wroclaw-logo-footer").forEach((img) => {
          img.src = src;
          img.alt = alt;
        });
        const euHeader = document.getElementById("eu-logo-header");
        const euFooter = document.getElementById("eu-logo-footer");
        const euSrc = lang === "pl" ? `${base}assets/PL_Co-fundedbytheEU_RGB_POS.png` : `${base}assets/EN_Co-fundedbytheEU_RGB_POS.png`;
        if (euHeader) {
          euHeader.src = euSrc;
          euHeader.alt = lang === "pl" ? "Dofinansowane przez Unię Europejską" : "Co-funded by the European Union";
        }
        if (euFooter) {
          euFooter.src = euSrc;
          euFooter.alt = lang === "pl" ? "Współfinansowane przez Unię Europejską" : "Co-funded by the European Union";
        }
        if (persist) {
          try {
            localStorage.setItem(LANG_STORAGE_KEY, lang);
          } catch (error) {}
        }
      }

      document.getElementById("btn-pl").addEventListener("click", () => setLang("pl"));
      document.getElementById("btn-en").addEventListener("click", () => setLang("en"));
      setLang(getSavedLang(), false);
      document.getElementById("hamburger-btn").addEventListener("click", () => {
        const nav = document.getElementById("mobile-nav");
        const isOpen = nav.classList.toggle("open");
        document.getElementById("hamburger-btn").setAttribute("aria-expanded", isOpen);
      });
    </script>
  </body>
</html>
